# Variables de entorno de EJEMPLO (copiar a .env y completar valores reales)
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANTE: El archivo .env NUNCA debe subirse a Git

# Base de datos (entorno de desarrollo local con Docker)
POSTGRES_HOST=mediconnect-postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mediconnect

# URL de la API backend (cuando exista)
API_URL=http://localhost:3000

# Supabase (para cuando se migre a producción)
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
